# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Early bird (launch mode) — free workspace; show $49 as regular price in UI
EARLY_BIRD_FREE=true
NEXT_PUBLIC_EARLY_BIRD=true

# Auth — required for saving programs (Google OAuth)
# Generate secret: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe — keep configured but disabled until early bird ends
# Set NEXT_PUBLIC_STRIPE_CHECKOUT_ENABLED=true when ready to charge
NEXT_PUBLIC_STRIPE_CHECKOUT_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Database (future — Supabase)
# DATABASE_URL=

# Analytics (Sprint 6)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=groundwork.example.com

# Contact form email (optional)
# RESEND_API_KEY=
# CONTACT_EMAIL_TO=team@example.com
# CONTACT_EMAIL_FROM=Groundwork <noreply@example.com>

# Dev-only: grant pass without Google (development only)
# DEV_SEASON_PASS_EMAIL=you@example.com
